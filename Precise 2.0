createSmartInput("P4 SIZE", 530, Settings.P4_Size, "P4_Size", true)

createSmartInput("WALK SPEED", 580, Settings.WalkSpeed, "WalkSpeed", true)
createSmartInput("PUNCH SPEED", 620, Settings.PunchSpeed, "PunchSpeed", true)
-- --------------------------------

local function createToggle(text, pos, key)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0, 270, 0, 30)
    btn.Position = UDim2.new(0, 25, 0, pos)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    Instance.new("UICorner", btn)

    local function update()
        btn.Text = text .. ": " .. (Settings[key] and "ON" or "OFF")
        btn.BackgroundColor3 = Settings[key] and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(40, 40, 45)
    end
    btn.MouseButton1Click:Connect(function() Settings[key] = not Settings[key] update() end)
    update()
end

-- COMPACT TOGGLES AT BOTTOM
createToggle("AI BOX MODE", 670, "AI_Box_Enabled")
createToggle("SMART BOX (STOPS ON KO)", 710, "SmartBox")
createToggle("ANTI-STUN / SLOW", 750, "AntiWeave")
createToggle("WS PROTECTION", 790, "WS_Protection")
createToggle("SOLID SHELL", 830, "SolidToggle")
createToggle("TP WALK (])", 870, "TPWalkEnabled")

-- LOGIC
local function getKnocked(p)
    local l = workspace:FindFirstChild("Live")
    local e = l and l:FindFirstChild(p.Name)
    local k = e and e:FindFirstChild("Knocked")
    return k and k.Value or false
end

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local myRoot = char and char:FindFirstChild("HumanoidRootPart")
    local anim = hum and hum:FindFirstChildOfClass("Animator")

    if hum then
        hum.WalkSpeed = Settings.TPWalkEnabled and 70 or Settings.WalkSpeed
        if Settings.AntiWeave then
            for _, c in ipairs(char:GetChildren()) do
                if table.find({"WeaveStun", "Stun", "Slow", "Weight"}, c.Name) then c:Destroy() end
            end
        end
    end

    local stomping = false
    activePunchType = nil
    if anim then
        for _, t in ipairs(anim:GetPlayingAnimationTracks()) do
            local id = tostring(t.Animation.AnimationId):lower()
            if stompIDs[id] then 
                stomping = true 
                t:AdjustSpeed(Settings.StompSpeed)
            elseif punchIDs[id] then 
                activePunchType = punchIDs[id]
                if Settings.PunchEnabled then t:AdjustSpeed(Settings.PunchSpeed) end
            end
        end
    end

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and myRoot then
            local root = v.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = (myRoot.Position - root.Position).Magnitude
                local isTarget = (Settings.TargetPlayer ~= "" and v.Name:lower():find(Settings.TargetPlayer:lower()))
                
                local size, trans = Settings.HRP_Size, Settings.HRP_Trans

                if stomping and dist <= LIMIT_DISTANCE then
                    size, trans = Settings.Stomp_HRP_Size, Settings.Stomp_HRP_Trans
                elseif Settings.AI_Box_Enabled and activePunchType and dist <= LIMIT_DISTANCE then
                    size, trans = Settings[activePunchType.."_Size"], Settings.AI_Box_Trans
                elseif isTarget then
                    size, trans = Settings.Target_HRP_Size, Settings.Target_HRP_Trans
                end

                if Settings.SmartBox and getKnocked(v) then
                    root.Size = Vector3.new(Settings.Off_Size, Settings.Off_Size, Settings.Off_Size)
                    root.Transparency = Settings.Off_Trans
                else
                    root.Size = Vector3.new(size, size, size)
                    root.Transparency = trans
                end
                root.CanCollide = false
            end
        end
    end
end)

UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.M then MainFrame.Visible = not MainFrame.Visible end
    if i.KeyCode == Enum.KeyCode.RightBracket then Settings.TPWalkEnabled = not Settings.TPWalkEnabled end
end)
