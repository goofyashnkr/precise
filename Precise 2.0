-- CONFIGURATION
local Settings = {
    HRP_Size = 3,
    HRP_Trans = 0.8,
    TargetPlayer = "", 
    Target_HRP_Size = 6, 
    Target_HRP_Trans = 0.5,
    Stomp_HRP_Size = 8,
    Stomp_HRP_Trans = 0.7,
    
    -- AI BOX SETTINGS
    AI_Box_Enabled = false,
    AI_Box_Trans = 0.5, 
    P1_Size = 6,
    P2_Size = 7,
    P3_Size = 8,
    P4_Size = 10,
    
    Off_Size = 2, 
    Off_Trans = 1, 
    SolidToggle = false,
    Solid_Size = 5,
    WalkSpeed = 11.5,           
    WS_Protection = true,  
    AntiWeave = true,
    TPWalkEnabled = false,
    SmartBox = false, 
    PunchEnabled = false, 
    PunchSpeed = 1.7,
    StompSpeed = 1.0
}

local isTriggerHeld = false
local isStomping = false 
local activePunchType = nil 
local LIMIT_DISTANCE = 35 

-- Animation IDs
local punchIDs = {
    ["rbxassetid://18312333191"] = "P1", ["rbxassetid://18312335714"] = "P2",
    ["rbxassetid://18312338197"] = "P3", ["rbxassetid://18312340119"] = "P4",
}
local stompIDs = { ["rbxassetid://17837722603"] = true, ["rbxassetid://18362264385"] = true }

-- UI SETUP
local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "PRECISE_2.0_CLASSIC_SPACED"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 320, 0, 920) 
MainFrame.Position = UDim2.new(0.5, -160, 0.5, -460)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true

local UICorner = Instance.new("UICorner", MainFrame)

local Title = Instance.new("TextLabel", MainFrame)
Title.Text = "PRECISE 2.0"
Title.Size = UDim2.new(1, 0, 0, 50)
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 18
Title.BackgroundTransparency = 1

local function createSmartInput(text, pos, default, key, isNumber)
    local lab = Instance.new("TextLabel", MainFrame)
    lab.Position = UDim2.new(0, 20, 0, pos)
    lab.Size = UDim2.new(0, 140, 0, 25)
    lab.Text = text
    lab.TextColor3 = Color3.fromRGB(200, 200, 200)
    lab.BackgroundTransparency = 1
    lab.Font = Enum.Font.GothamSemibold
    lab.TextSize = 12
    lab.TextXAlignment = Enum.TextXAlignment.Left

    local box = Instance.new("TextBox", MainFrame)
    box.Size = UDim2.new(0, 80, 0, 22)
    box.Position = UDim2.new(0, 210, 0, pos)
    box.Text = tostring(default)
    box.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.Font = Enum.Font.Gotham
    box.TextSize = 11
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)

    box.FocusLost:Connect(function()
        Settings[key] = isNumber and (tonumber(box.Text:match("[%d%.]+")) or default) or box.Text
        box.Text = tostring(Settings[key])
    end)
end

