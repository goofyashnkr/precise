-- ==================================================================
-- UTILITIES & MORPHER
-- ==================================================================
local function LocalMorph(targetUser)
    local targetId = nil
    pcall(function() targetId = Players:GetUserIdFromNameAsync(targetUser) end)
    if not targetId then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    local desc = nil
    pcall(function() desc = Players:GetHumanoidDescriptionFromUserId(targetId) end)
    
    if hum and desc then
        -- Clear existing 
        for _, v in pairs(char:GetChildren()) do
            if v:IsA("Accessory") or v:IsA("Shirt") or v:IsA("Pants") or v:IsA("BodyColors") or v:IsA("ShirtGraphic") then
                v:Destroy()
            end
        end
        
        -- Body Colors
        local bc = Instance.new("BodyColors", char)
        bc.HeadColor3 = desc.HeadColor; bc.LeftArmColor3 = desc.LeftArmColor; bc.RightArmColor3 = desc.RightArmColor
        bc.LeftLegColor3 = desc.LeftLegColor; bc.RightLegColor3 = desc.RightLegColor; bc.TorsoColor3 = desc.TorsoColor

        -- Clothing
        if desc.Shirt ~= 0 then local s = Instance.new("Shirt", char); s.ShirtTemplate = "rbxassetid://"..desc.Shirt end
        if desc.Pants ~= 0 then local p = Instance.new("Pants", char); p.PantsTemplate = "rbxassetid://"..desc.Pants end
        
        -- Local Accessory loading
        local look = Players:GetCharacterAppearanceAsync(targetId)
        for _, obj in pairs(look:GetChildren()) do
            if obj:IsA("Accessory") or obj:IsA("Shirt") or obj:IsA("Pants") then
                obj.Parent = char
            end
        end
    end
end

mBtn.MouseButton1Click:Connect(function() LocalMorph(mBox.Text) end)

local function removeSelectionBox(targetPlayer)
    if selectionBoxCache[targetPlayer] then
        pcall(function() selectionBoxCache[targetPlayer]:Destroy() end)
        selectionBoxCache[targetPlayer] = nil
    end
end

local function resetHRP(targetPlayer, char)
    local props = originalHRPProps[targetPlayer]
    if props and char then
        local Root = char:FindFirstChild("HumanoidRootPart")
        if Root then
            Root.Size = props.Size
            Root.Transparency = props.Transparency
            Root.CanCollide = props.CanCollide
            Root.Color = props.Color
            Root.CanTouch = true
            Root.CanQuery = true
            local shell = Root:FindFirstChild("SolidShell")
            if shell then shell:Destroy() end
        end
    end
    removeSelectionBox(targetPlayer)
end

-- ==================================================================
-- CORE LOGIC
-- ==================================================================
local function LoadConfigs()
    for _, v in pairs(scrl:GetChildren()) do if v:IsA("Frame") then v:Destroy() end end
    if listfiles then
        for _, file in pairs(listfiles(ConfigFolder)) do
            local n = file:match("([^\\/%.]+)%.json$")
            local f = Instance.new("Frame", scrl); f.Size = UDim2.new(1,-6,0,38); f.BackgroundColor3 = Color3.fromRGB(28,28,32); Instance.new("UICorner", f)
            local t = Instance.new("TextLabel", f); t.Size = UDim2.new(0.4,0,1,0); t.Text = n; t.TextColor3 = Color3.new(1,1,1); t.BackgroundTransparency = 1; t.Position = UDim2.new(0,10,0,0); t.TextXAlignment = 0
            local lB = Instance.new("TextButton", f); lB.Size = UDim2.new(0.25,0,0.7,0); lB.Position = UDim2.new(0.45,0,0.15,0); lB.Text = "LOAD"; lB.BackgroundColor3 = Color3.fromRGB(50,50,55); lB.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", lB)
            local dB = Instance.new("TextButton", f); dB.Size = UDim2.new(0.25,0,0.7,0); dB.Position = UDim2.new(0.72,0,0.15,0); dB.Text = "DEL"; dB.BackgroundColor3 = Color3.fromRGB(100,30,30); dB.TextColor3 = Color3.new(1,1,1); Instance.new("UICorner", dB)
            
            lB.MouseButton1Click:Connect(function()
                local d = HttpService:JSONDecode(readfile(file))
                for k, v in pairs(d) do 
                    if k == "AccentColor" then Settings[k] = Color3.new(v[1], v[2], v[3]) 
                    elseif k == "MenuKey" then Settings[k] = Enum.KeyCode[v] 
                    else Settings[k] = v end 
                end
                RefreshAllUI() 
            end)
            dB.MouseButton1Click:Connect(function() delfile(file) f:Destroy() end)
        end
    end
end

sBtn.MouseButton1Click:Connect(function()
    local d = {}
    for k, v in pairs(Settings) do 
        if typeof(v) == "Color3" then d[k] = {v.R, v.G, v.B} 
        elseif typeof(v) == "EnumItem" then d[k] = v.Name 
        else d[k] = v end 
    end
    writefile(ConfigFolder.."/"..(cfgBox.Text ~= "" and cfgBox.Text or "Preset")..".json", HttpService:JSONEncode(d))
    LoadConfigs()
end)
LoadConfigs()

-- WEAVE GLIDE LOGIC
local function boostWeaveDistance(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if not hrp then return end
    hrp.ChildAdded:Connect(function(child)
        if child:IsA("BodyPosition") and child:GetAttribute("m") == 1 then
            local currentPos = child.Position
            local hrpPos = hrp.Position
            local direction = (currentPos - hrpPos)
            if direction.Magnitude > 0 then
                local targetDistance = Settings.GlideEnabled and Settings.GlidePower or 2.2
                child.Position = hrpPos + (direction.Unit * targetDistance)
            end
        end
    end)
end
if LocalPlayer.Character then boostWeaveDistance(LocalPlayer.Character) end
LocalPlayer.CharacterAdded:Connect(boostWeaveDistance)

-- HEARTBEAT UPDATES
RunService.Heartbeat:Connect(function(dt)
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local myRoot = char and char:FindFirstChild("HumanoidRootPart")
    local animator = hum and hum:FindFirstChildOfClass("Animator")
    
    -- PERSISTENT HEADLESS ADDITION
    if char then
        local head = char:FindFirstChild("Head")
        if head then
            local headTrans = Settings.HeadlessEnabled and 1 or 0
            if head.Transparency ~= headTrans then
                head.Transparency = headTrans
                for _, v in pairs(head:GetDescendants()) do 
                    if v:IsA("BasePart") or v:IsA("Decal") then 
                        v.Transparency = headTrans 
                    end 
                end
            end
        end
    end

    if hum then
        local targetSpeed = Settings.TPWalkEnabled and TP_SPEED or Settings.WalkSpeed
        if (not Settings.WS_Protection or not isTriggerHeld) then hum.WalkSpeed = targetSpeed end
        if Settings.AntiWeave then
            for _, child in ipairs(char:GetChildren()) do
                if table.find({"WeaveStun", "Stun", "Slow", "Weight"}, child.Name) then child:Destroy() end
            end
        end

        -- ANIMATION SPEED LOGIC (Original)
        isStomping = false
        activePunchType = nil
        if animator then
            for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
                if punchIDs[track.Animation.AnimationId] then
                    activePunchType = punchIDs[track.Animation.AnimationId]
                    if Settings.PunchEnabled then track:AdjustSpeed(Settings.PunchSpeed) end
                end
                if stompIDs[track.Animation.AnimationId] then
                    isStomping = true
                    track:AdjustSpeed(Settings.StompSpeed)
                end
            end
        end
    end

    -- Hitbox Logic
    lastHitboxUpdate = lastHitboxUpdate + dt
    if lastHitboxUpdate >= hitboxUpdateRate then
        lastHitboxUpdate = 0
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer then
                local tChar = v.Character
                local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
                local tHum = tChar and tChar:FindFirstChildOfClass("Humanoid")
                if tRoot and tHum and myRoot then
                    local dist = (myRoot.Position - tRoot.Position).Magnitude
                    if dist <= Settings.RenderDistance then
                        if not originalHRPProps[v] then
                            originalHRPProps[v] = {Size = tRoot.Size, Transparency = tRoot.Transparency, CanCollide = tRoot.CanCollide, Color = tRoot.Color}
                        end
                        
                        -- Priority Hierarchy Logic (Original)
                        local finalSize = Settings.HRP_Size
                        local finalTrans = Settings.HRP_Trans
                        
                        if isStomping then
                            finalSize = Settings.Stomp_HRP_Size
                            finalTrans = Settings.Stomp_HRP_Trans
                        elseif activePunchType == "P1" then finalSize = Settings.P1_Size
                        elseif activePunchType == "P2" then finalSize = Settings.P2_Size
                        elseif activePunchType == "P3" then finalSize = Settings.P3_Size
                        elseif activePunchType == "P4" then finalSize = Settings.P4_Size
                        elseif Settings.TargetPlayer ~= "" and (v.Name:lower():find(Settings.TargetPlayer:lower()) or v.DisplayName:lower():find(Settings.TargetPlayer:lower())) then
                            finalSize = Settings.Target_HRP_Size
                            finalTrans = Settings.Target_HRP_Trans
                        elseif Settings.SmartBox and activePunchType == nil and not isStomping then
                            finalSize = Settings.Off_Size
                            finalTrans = Settings.Off_Trans
                        end
                        
                        if Settings.AI_Box_Enabled and v:FindFirstChild("Target") then
                            finalSize = 12
                        end

                        tRoot.Size = Vector3.new(finalSize, finalSize, finalSize)
                        tRoot.Transparency = finalTrans
                        tRoot.CanCollide = false
                        tRoot.CanTouch = true
                        tRoot.CanQuery = true

                        -- Solid Shell (Original)
                        local shell = tRoot:FindFirstChild("SolidShell")
                        if Settings.SolidToggle then
                            if not shell then
                                shell = Instance.new("Part", tRoot); shell.Name = "SolidShell"; shell.Shape = Enum.PartType.Ball; shell.Transparency = 1; shell.CanCollide = true; shell.CanTouch = false; shell.CanQuery = false
                                local weld = Instance.new("Weld", shell); weld.Part0 = tRoot; weld.Part1 = shell
                            end
                            shell.Size = Vector3.new(Settings.Solid_Size, Settings.Solid_Size, Settings.Solid_Size)
                        elseif shell then
                            shell:Destroy()
                        end
                        
                        if Settings.SelectionBoxEnabled then
                            local sb = selectionBoxCache[v]
                            if not sb then
                                sb = Instance.new("SelectionBox", tRoot); sb.Adornee = tRoot; sb.LineThickness = 0.02; selectionBoxCache[v] = sb
                            end
                            sb.Color3 = (Settings.TargetPlayer ~= "" and (v.Name:lower():find(Settings.TargetPlayer:lower()) or v.DisplayName:lower():find(Settings.TargetPlayer:lower()))) and Color3.new(1,0,0) or Settings.AccentColor
                        end
                    else
                        resetHRP(v, tChar)
                    end
                end
            end
        end
    end
end)

-- THEME
local colors = {Color3.fromRGB(0, 170, 255), Color3.fromRGB(255, 50, 50), Color3.fromRGB(50, 255, 100), Color3.fromRGB(255, 200, 50), Color3.fromRGB(180, 50, 255)}
for _, cval in pairs(colors) do
    local c = Instance.new("TextButton", ThemeFrame); c.Size = UDim2.new(0, 32, 0, 32); c.BackgroundColor3 = cval; c.Text = ""
    Instance.new("UICorner", c).CornerRadius = UDim.new(0, 8)
    c.MouseButton1Click:Connect(function() Settings.AccentColor = cval RefreshAllUI() end)
end

-- KEY INPUTS
UserInputService.InputBegan:Connect(function(i, gp)
    if gp then return end
    if i.KeyCode == Settings.MenuKey then MainFrame.Visible = not MainFrame.Visible end
    if i.KeyCode == Enum.KeyCode.LeftShift then sprintInputHeld = true end
    if i.KeyCode == Enum.KeyCode.Space then isTriggerHeld = true end
    if i.KeyCode == Enum.KeyCode.RightBracket then Settings.TPWalkEnabled = not Settings.TPWalkEnabled end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.KeyCode == Enum.KeyCode.LeftShift then sprintInputHeld = false end
    if i.KeyCode == Enum.KeyCode.Space then isTriggerHeld = false end
end)
