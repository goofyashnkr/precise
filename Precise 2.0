local Pages, TabButtons, UIObjects = {}, {}, {}

local function RefreshAllUI()
    MainFrame.BackgroundTransparency = Settings.GuiTransparency
    for name, btn in pairs(TabButtons) do 
        if Pages[name].Visible then btn.BackgroundColor3 = Settings.AccentColor end 
    end
    for _, obj in pairs(UIObjects) do
        if obj.type == "Toggle" then
            obj.btn.Text = obj.rawText .. ": " .. (Settings[obj.key] and "ON" or "OFF")
            obj.btn.BackgroundColor3 = Settings[obj.key] and Settings.AccentColor or Color3.fromRGB(45,45,50)
        elseif obj.type == "Slider" then
            local val = Settings[obj.key]
            obj.valInput.Text = tostring(val)
            obj.sFill.Size = UDim2.new(math.clamp((val - obj.min) / (obj.max - obj.min), 0, 1), 0, 1, 0)
            obj.sFill.BackgroundColor3 = Settings.AccentColor
        elseif obj.type == "Input" then
            obj.box.Text = tostring(Settings[obj.key])
        end
    end
end

local function CreateTab(name, index)
    local btn = Instance.new("TextButton", TabContainer)
    btn.Size = UDim2.new(0.24, 0, 1, 0); btn.Position = UDim2.new(index * 0.25, 0, 0, 0); btn.Text = name:upper(); btn.BackgroundColor3 = index == 0 and Settings.AccentColor or Color3.fromRGB(25,25,25); btn.TextColor3 = Color3.new(1,1,1); btn.Font = 17; btn.TextSize = 11; Instance.new("UICorner", btn)
    local page = Instance.new("Frame", ContentFrame); page.Size = UDim2.new(1, -30, 1, 0); page.Position = UDim2.new(0, 15, 0, 0); page.BackgroundTransparency = 1; page.Visible = (index == 0)
    Instance.new("UIListLayout", page).Padding = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(function()
        for _, p in pairs(Pages) do p.Visible = false end; for _, b in pairs(TabButtons) do b.BackgroundColor3 = Color3.fromRGB(25, 25, 25) end
        page.Visible = true; btn.BackgroundColor3 = Settings.AccentColor
    end)
    Pages[name] = page; TabButtons[name] = btn; return page
end

local function AddSlider(parent, text, key, min, max, manualCap)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(1, 0, 0, 45); f.BackgroundTransparency = 1
    local lab = Instance.new("TextLabel", f); lab.Size = UDim2.new(0.6, 0, 0.4, 0); lab.Text = text; lab.TextColor3 = Color3.new(1,1,1); lab.Font = 17; lab.TextSize = 12; lab.TextXAlignment = 0; lab.BackgroundTransparency = 1
    local valInput = Instance.new("TextBox", f); valInput.Size = UDim2.new(0.3, 0, 0.4, 0); valInput.Position = UDim2.new(0.7, 0, 0, 0); valInput.Text = tostring(Settings[key]); valInput.BackgroundTransparency = 1; valInput.TextColor3 = Color3.new(1,1,1); valInput.Font = 17; valInput.TextSize = 12; valInput.TextXAlignment = 2
    local sBack = Instance.new("Frame", f); sBack.Size = UDim2.new(1, 0, 0, 4); sBack.Position = UDim2.new(0, 0, 0.75, 0); sBack.BackgroundColor3 = Color3.fromRGB(40,40,40); Instance.new("UICorner", sBack)
    local sFill = Instance.new("Frame", sBack); sFill.Size = UDim2.new(math.clamp((Settings[key]-min)/(max-min),0,1), 0, 1, 0); sFill.BackgroundColor3 = Settings.AccentColor; Instance.new("UICorner", sFill)
    local Thumb = Instance.new("Frame", sFill); Thumb.AnchorPoint = Vector2.new(0.5, 0.5); Thumb.Position = UDim2.new(1, 0, 0.5, 0); Thumb.Size = UDim2.new(0, 16, 0, 16); Thumb.BackgroundColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", Thumb)

    local function update(val, isManual)
        if not isManual then val = math.clamp(math.round(val * 10) / 10, min, max) 
        elseif manualCap then val = math.clamp(val, min, manualCap) end
        Settings[key] = val
        valInput.Text = tostring(val)
        sFill.Size = UDim2.new(math.clamp((val-min)/(max-min), 0, 1), 0, 1, 0)
        if key == "GuiTransparency" then MainFrame.BackgroundTransparency = val end
    end

    local dragging = false
    Thumb.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end end)
    UserInputService.InputChanged:Connect(function(i) if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then update(min + (max - min) * math.clamp((i.Position.X - sBack.AbsolutePosition.X) / sBack.AbsoluteSize.X, 0, 1), false) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    valInput.FocusLost:Connect(function() update(tonumber(valInput.Text) or Settings[key], true) end)
    
    table.insert(UIObjects, {type = "Slider", key = key, min = min, max = max, valInput = valInput, sFill = sFill})
end

local function AddToggle(parent, text, key)
    local btn = Instance.new("TextButton", parent); btn.Size = UDim2.new(1, 0, 0, 32); btn.TextColor3 = Color3.new(1,1,1); btn.Font = 17; btn.TextSize = 12; Instance.new("UICorner", btn)
    local function update() btn.Text = text..": "..(Settings[key] and "ON" or "OFF"); btn.BackgroundColor3 = Settings[key] and Settings.AccentColor or Color3.fromRGB(45,45,50) end
    btn.MouseButton1Click:Connect(function() Settings[key] = not Settings[key] update() end); update()
    
    table.insert(UIObjects, {type = "Toggle", key = key, btn = btn, rawText = text})
end

local function AddInput(parent, text, key)
    local f = Instance.new("Frame", parent); f.Size = UDim2.new(1, 0, 0, 32); f.BackgroundTransparency = 1
    local lab = Instance.new("TextLabel", f); lab.Size = UDim2.new(0.4, 0, 1, 0); lab.Text = text; lab.TextColor3 = Color3.new(1,1,1); lab.Font = 17; lab.TextSize = 12; lab.TextXAlignment = 0; lab.BackgroundTransparency = 1
    local box = Instance.new("TextBox", f); box.Size = UDim2.new(0.55, 0, 1, 0); box.Position = UDim2.new(0.45, 0, 0, 0); box.Text = tostring(Settings[key]); box.BackgroundColor3 = Color3.fromRGB(20,20,20); box.TextColor3 = Color3.new(1,1,1); box.Font = 17; box.TextSize = 11; Instance.new("UICorner", box)
    box.FocusLost:Connect(function() Settings[key] = box.Text end)
    
    table.insert(UIObjects, {type = "Input", key = key, box = box})
end

