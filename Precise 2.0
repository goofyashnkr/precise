-- [[ CONFIGURATION ]]

-- Fetches keys from your GitHub
local Success, KeyData = pcall(function()
    return game:HttpGet("https://raw.githubusercontent.com/goofyashnkr/Linear/refs/heads/main/KEYS")
end)

-- URLs for the scripts
local PRECISE_URL = "https://raw.githubusercontent.com/goofyashnkr/precise/refs/heads/main/PRECISE"
local LINEAR_URL  = "https://raw.githubusercontent.com/goofyashnkr/Linear/refs/heads/main/LINEAR%20SCRIPT"

-- [[ UI SETUP ]]
local TweenService = game:GetService("TweenService")
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 850, 0, 850)
MainFrame.Position = UDim2.new(0.5, -425, 0.5, -425)
MainFrame.BackgroundTransparency = 1 

-- [[ EXECUTION ENGINE ]]
local function executeScript(mode)
    local targetUrl = (mode == "PRECISE") and PRECISE_URL or LINEAR_URL
    
    -- Attempt to download the script content
    local downloadSuccess, scriptContent = pcall(function()
        return game:HttpGet(targetUrl)
    end)

    if downloadSuccess and scriptContent then
        -- Attempt to load the string
        local loadedFunc, loadError = loadstring(scriptContent)
        
        if loadedFunc then
            ScreenGui:Destroy() -- Clean up UI
            task.spawn(loadedFunc) -- Run the script in a new thread
        else
            warn("!! SYNTAX ERROR IN GITHUB SCRIPT !!")
            warn(loadError)
        end
    else
        warn("!! FAILED TO DOWNLOAD SCRIPT FROM GITHUB !!")
        warn("Link tried: " .. targetUrl)
    end
end

-- [[ UI BUILDER FUNCTION ]]
local function createTile(name, pos, color)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0, 380, 0, 380)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = name
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 45
    btn.TextColor3 = color
    btn.AutoButtonColor = false
    
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 40)
    local stroke = Instance.new("UIStroke", btn)
    stroke.Thickness = 3
    stroke.Color = color
    stroke.Transparency = 0.5

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 0, Thickness = 5}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(30, 30, 30)}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.3), {Transparency = 0.5, Thickness = 3}):Play()
    end)
    
    return btn
end

local PreciseBtn = createTile("PRECISE 2.0", UDim2.new(0.02, 0, 0.25, 0), Color3.fromRGB(0, 170, 255))
local LinearBtn = createTile("LINEAR", UDim2.new(0.53, 0, 0.25, 0), Color3.fromRGB(160, 160, 160))

-- [[ LOGIC ]]

-- PRECISE Logic
PreciseBtn.MouseButton1Click:Connect(function()
    executeScript("PRECISE")
end)

-- LINEAR Logic
LinearBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
    
    local KeyFrame = Instance.new("Frame", ScreenGui)
    KeyFrame.Size = UDim2.new(0, 450, 0, 320)
    KeyFrame.Position = UDim2.new(0.5, -225, 0.5, -160)
    KeyFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Instance.new("UICorner", KeyFrame).CornerRadius = UDim.new(0, 20)
    
    local input = Instance.new("TextBox", KeyFrame)
    input.Size = UDim2.new(0.8, 0, 0, 60)
    input.Position = UDim2.new(0.1, 0, 0.15, 0)
    input.PlaceholderText = "ENTER LINEAR KEY"
    input.Text = ""
    input.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    input.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", input)

    local submit = Instance.new("TextButton", KeyFrame)
    submit.Size = UDim2.new(0.8, 0, 0, 60)
    submit.Position = UDim2.new(0.1, 0, 0.45, 0)
    submit.BackgroundColor3 = Color3.fromRGB(160, 160, 160)
    submit.Text = "LOGIN"
    submit.Font = Enum.Font.GothamBold
    Instance.new("UICorner", submit)

    local back = Instance.new("TextButton", KeyFrame)
    back.Size = UDim2.new(0, 100, 0, 30)
    back.Position = UDim2.new(0.5, -50, 0.8, 0)
    back.BackgroundTransparency = 1
    back.Text = "← BACK"
    back.TextColor3 = Color3.fromRGB(120, 120, 120)
    back.TextSize = 14

    back.MouseButton1Click:Connect(function()
        KeyFrame:Destroy()
        MainFrame.Visible = true
    end)

    submit.MouseButton1Click:Connect(function()
        local userInput = input.Text:gsub("%s+", "")
        local authorized = false
        
        if Success and KeyData then
            for key in KeyData:gmatch("[^\r\n]+") do
                if key:gsub("%s+", "") == userInput then
                    authorized = true
                    break
                end
            end
        end

        if authorized and userInput ~= "" then
            KeyFrame:Destroy()
            executeScript("LINEAR")
        else
            input.Text = ""
            input.PlaceholderText = "INVALID KEY"
            input.PlaceholderColor3 = Color3.new(1, 0, 0)
        end
    end)
end)
